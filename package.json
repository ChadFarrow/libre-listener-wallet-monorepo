{
  "name": "libre-listener-wallet-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check:storage": "pnpm --filter @libre/listener-wallet exec vitest run src/tests/unit/storage-contract.test.ts && pnpm --filter @libre/example-app exec vitest run src/core/storage-contract.test.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5"
  },
  "msw": {
    "workerDirectory": [
      "packages/example-app/public"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}