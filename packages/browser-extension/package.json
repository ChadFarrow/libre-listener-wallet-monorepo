{
  "name": "@libre/browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "MV3 browser extension that hosts the Libre Listener Wallet and injects a WebLN (window.webln) provider so any web app can tie into the wallet.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libre/listener-wallet": "workspace:*",
    "@libre/shared": "workspace:*",
    "lightningdevkit": "^0.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "esbuild": "^0.23.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
